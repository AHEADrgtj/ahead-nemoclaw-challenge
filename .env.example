# Copy this to a new file named .env and fill in your values.
# Your .env is gitignored and will be auto-loaded by dev scripts.

NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_MODEL=meta/llama-3.1-8b-instruct

# For NVIDIA cloud API (default):
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1

# For a local NemoClaw/vLLM/Ollama instance, uncomment and set:
# NVIDIA_API_BASE=http://localhost:8080/v1

# Bridge adapter: mock | http | openclaw
# - mock:     No external calls, synthetic responses (no API key needed)
# - http:     Python bridge in Docker, real NVIDIA inference
# - openclaw: NemoClaw sandbox on host (see QUICKSTART.md)
# BRIDGE_ADAPTER=mock

# AHEAD SecOps Runtime URL (used in ServiceNow ticket links)
AHEAD_SECOPS_URL=http://localhost:4500
